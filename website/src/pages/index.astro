---
import Base from '../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';

// Fallback accent colour per pack — only used when no cover image is found.
// Add a line here when creating a new pack if you want a custom fallback.
const packAccent: Record<string, string> = {
  flag_adventure:  '#f59e0b',
  number_cells:    '#6366f1',
  rotate_flip:     '#8b5cf6',
  diagonal_swipes: '#10b981',
  flood_colors:    '#06b6d4',
  box_builder:     '#f97316',
};

// Packs that are shared asset libraries, not playable games — skip them.
const SKIP_PACKS = new Set(['gridponder-base', 'rabbit-character']);

const packsDir = path.resolve(process.cwd(), '../packs');
const packs = fs.readdirSync(packsDir)
  .filter(id => {
    if (SKIP_PACKS.has(id)) return false;
    return fs.existsSync(path.join(packsDir, id, 'manifest.json'));
  })
  .map(id => {
    const manifest = JSON.parse(fs.readFileSync(path.join(packsDir, id, 'manifest.json'), 'utf-8'));
    const gameJsonPath = path.join(packsDir, id, 'game.json');
    const levelCount = fs.existsSync(gameJsonPath)
      ? JSON.parse(fs.readFileSync(gameJsonPath, 'utf-8'))
          .levelSequence?.filter((e: any) => e.type === 'level').length ?? 0
      : 0;
    const coverFile = path.join(process.cwd(), `../packs/${id}`, manifest.coverImage ?? '');
    const hasCover = manifest.coverImage && fs.existsSync(coverFile);
    const coverSrc = hasCover ? `/pack-covers/${id}.png` : null;
    const accent = packAccent[id] ?? '#7c3aed';
    const description = (manifest.shortDescription as string | undefined)
      ?? (manifest.description as string);
    return { id, name: manifest.title as string, description, levels: levelCount, coverSrc, accent };
  })
  // Show packs with at least one level first; within each group keep filesystem order
  .sort((a, b) => (b.levels > 0 ? 1 : 0) - (a.levels > 0 ? 1 : 0));
---
<Base title="GridPonder">
  <!-- Hero -->
  <section class="grid-bg relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-24 sm:py-32">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-brand-50 text-brand-700 text-sm font-medium px-3 py-1 rounded-full mb-6 border border-brand-100">
          <span>Open source</span>
          <span class="text-brand-300">·</span>
          <span>AI-friendly</span>
        </div>
        <h1 class="text-5xl sm:text-7xl font-black tracking-tight text-gray-900 mb-6 leading-none">
          Grid<span class="text-brand-600">Ponder</span>
        </h1>
        <p class="text-xl sm:text-2xl text-gray-600 mb-4 leading-relaxed max-w-2xl">
          A lightweight puzzle medium. Design elegant grid games as structured data — no code required.
          Play, share, and extend.
        </p>
        <p class="text-base text-gray-500 mb-10">
          Games are defined in a declarative DSL and run by a fixed engine.
          A creator with Claude Code can build a playable game in minutes.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/play"
             class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors shadow-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Play in Browser
          </a>
          <a href="https://github.com/Gridponder" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-800 font-semibold px-6 py-3 rounded-xl transition-colors border border-gray-200 shadow-sm">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            View on GitHub
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative grid tiles -->
    <div class="absolute top-12 right-0 w-96 h-96 opacity-30 hidden lg:block" aria-hidden="true">
      <div class="grid grid-cols-5 gap-2 p-4">
        {Array.from({length: 25}).map((_, i) => (
          <div class={`aspect-square rounded-lg border-2 ${
            [2,6,8,12,16,18,22].includes(i) ? 'bg-brand-500 border-brand-600' :
            [1,7,13,17,23].includes(i) ? 'bg-amber-400 border-amber-500' :
            'bg-gray-100 border-gray-200'
          }`} />
        ))}
      </div>
    </div>
  </section>

  <!-- Three pillars -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="group p-8 rounded-2xl border border-gray-100 hover:border-brand-200 hover:shadow-md transition-all bg-white">
        <div class="text-4xl mb-4">🎮</div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Play</h2>
        <p class="text-gray-600 leading-relaxed">
          Curated puzzle games in a consistent player experience. Works on iOS, Android, macOS, and in your browser.
          Each game is a self-contained pack that loads and runs without engine code changes.
        </p>
      </div>
      <div class="group p-8 rounded-2xl border border-gray-100 hover:border-brand-200 hover:shadow-md transition-all bg-white">
        <div class="text-4xl mb-4">✏️</div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Create</h2>
        <p class="text-gray-600 leading-relaxed">
          Define games as structured data using the GridPonder DSL — JSON files that describe boards, entities, rules, and goals.
          No programming required. A Claude Code session walks you through it.
        </p>
      </div>
      <div class="group p-8 rounded-2xl border border-gray-100 hover:border-brand-200 hover:shadow-md transition-all bg-white">
        <div class="text-4xl mb-4">📦</div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Share</h2>
        <p class="text-gray-600 leading-relaxed">
          Zip a game folder and share the link. Anyone with the app can import it instantly.
          High quality games can be submitted to the main repository for wider distribution.
        </p>
      </div>
    </div>
  </section>

  <!-- Game packs -->
  <section class="bg-gray-50 border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-2">Game Packs</h2>
          <p class="text-gray-500">{packs.length} puzzle mechanics, each with multiple handcrafted levels</p>
        </div>
        <a href="/play" class="text-brand-600 hover:text-brand-700 font-medium text-sm transition-colors hidden sm:block">
          Play all →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {packs.map(pack => (
          <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden flex flex-col hover:shadow-md hover:border-gray-300 transition-all">
            <!-- Cover image -->
            <div class="relative h-72 flex-shrink-0 flex items-center justify-center overflow-hidden"
                 style={`background-color: ${pack.accent}22`}>
              {pack.coverSrc
                ? <img src={pack.coverSrc} alt={pack.name}
                       class="w-full h-full object-cover" loading="lazy" />
                : <span class="text-6xl opacity-40">⊞</span>
              }
              <span class="absolute top-3 right-3 text-xs font-semibold px-2 py-1 rounded-full bg-black/40 text-white backdrop-blur-sm">
                {pack.levels} level{pack.levels !== 1 ? 's' : ''}
              </span>
            </div>
            <!-- Text -->
            <div class="p-5 flex flex-col gap-1">
              <h3 class="font-bold text-gray-900 text-lg leading-snug">{pack.name}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{pack.description}</p>
            </div>
          </div>
        ))}
        <!-- More coming -->
        <div class="border-2 border-dashed border-gray-200 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 text-center min-h-[160px]">
          <span class="text-3xl text-gray-300">⊞</span>
          <p class="text-gray-400 text-sm font-medium">More packs coming — or create yours</p>
          <a href="/dsl" class="text-brand-600 hover:text-brand-700 text-sm font-semibold transition-colors">Read the DSL →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- DSL / Creator CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <div class="bg-gradient-to-br from-brand-700 to-brand-900 rounded-3xl p-10 sm:p-16 text-white relative overflow-hidden">
      <!-- Decorative -->
      <div class="absolute inset-0 opacity-10">
        <div class="grid-bg w-full h-full" />
      </div>
      <div class="relative max-w-2xl">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Want to create your own game?</h2>
        <p class="text-brand-200 text-lg mb-8 leading-relaxed">
          GridPonder games are pure data — no code, just JSON files that describe the board, entities, and rules.
          The DSL is designed to be understood by both humans and AI assistants.
          A Claude Code session can guide you from idea to playable game in a single conversation.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/dsl"
             class="inline-flex items-center gap-2 bg-white text-brand-700 font-semibold px-6 py-3 rounded-xl hover:bg-brand-50 transition-colors">
            Read the DSL
          </a>
          <a href="/play#create"
             class="inline-flex items-center gap-2 border border-brand-400 text-white font-semibold px-6 py-3 rounded-xl hover:bg-brand-600 transition-colors">
            Creator Guide
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
