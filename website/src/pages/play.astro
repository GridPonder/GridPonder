---
import Base from '../layouts/Base.astro';
---
<Base
  title="Play"
  description="Play GridPonder puzzle games in your browser, or learn how to create your own."
>

  <!-- =====================================================================
       MOBILE VIEW  (hidden on lg+)
       Full-screen link + PWA install instructions + creator guide
       ===================================================================== -->
  <div class="lg:hidden max-w-lg mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Play GridPonder</h1>
    <p class="text-gray-500 mb-10">Play all puzzle packs directly in your browser — or add to your home screen for a native-app experience.</p>

    <!-- Primary CTA -->
    <a href="/game/"
       class="flex items-center justify-center gap-3 bg-brand-600 hover:bg-brand-700 text-white font-bold text-lg px-6 py-4 rounded-2xl transition-colors shadow-md mb-10">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Open Game
    </a>

    <!-- Add to Home Screen instructions -->
    <div class="mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-1">Add to Home Screen</h2>
      <p class="text-sm text-gray-500 mb-5">
        For a near-native experience with no browser chrome, add GridPonder to your home screen.
        It opens like an installed app.
      </p>
      <div class="space-y-4">
        <!-- iOS -->
        <div class="border border-gray-200 rounded-xl p-4">
          <div class="flex items-center gap-2 font-semibold text-gray-800 mb-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            iPhone / iPad (Safari or Chrome)
          </div>
          <ol class="text-sm text-gray-600 space-y-1 list-decimal list-inside">
            <li>Tap <strong class="text-gray-800">Open Game</strong> above</li>
            <li>Tap the <strong class="text-gray-800">Share</strong> button (square with arrow)</li>
            <li>Tap <strong class="text-gray-800">Add to Home Screen</strong></li>
            <li>Tap <strong class="text-gray-800">Add</strong> — done</li>
          </ol>
        </div>
        <!-- Android -->
        <div class="border border-gray-200 rounded-xl p-4">
          <div class="flex items-center gap-2 font-semibold text-gray-800 mb-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.341a8.021 8.021 0 01-11.046 0 8 8 0 010-11.317A7.95 7.95 0 0112 2a7.949 7.949 0 015.523 2.024l1.48-1.48A9.97 9.97 0 0012 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12a11.97 11.97 0 00-.561-3.627l-1.547 1.547c.07.353.108.717.108 1.08a8 8 0 01-4.477 7.341z"/></svg>
            Android (Chrome)
          </div>
          <ol class="text-sm text-gray-600 space-y-1 list-decimal list-inside">
            <li>Tap <strong class="text-gray-800">Open Game</strong> above</li>
            <li>Tap the <strong class="text-gray-800">⋮ menu</strong> (top right)</li>
            <li>Tap <strong class="text-gray-800">Add to Home Screen</strong></li>
            <li>Tap <strong class="text-gray-800">Install</strong> — done</li>
          </ol>
        </div>
      </div>
    </div>

    <!-- App stores -->
    <div class="mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-1">Native App</h2>
      <p class="text-gray-500 text-sm mb-4">A native iOS and Android app is planned. Stay tuned.</p>
      <div class="flex flex-wrap gap-3">
        <div class="flex items-center gap-3 bg-gray-900 text-white rounded-xl px-4 py-2.5 opacity-50 cursor-not-allowed select-none text-sm">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76c.33.19.7.24 1.07.14l12.6-12.6-2.85-2.84L3.18 23.76zM20.69 10.37l-2.44-1.41-3.19 3.19 3.19 3.19 2.45-1.41c.7-.4.7-1.56-.01-1.56zM4.25.1C3.88 0 3.51.05 3.18.24L14 11.06l3.05-3.06L4.25.1zM2.82 1.05C2.31 1.5 2 2.22 2 3.1v17.8c0 .88.31 1.6.82 2.05l.12.1 9.97-9.97v-.22L2.94.95l-.12.1z"/></svg>
          <span><span class="text-gray-400 text-xs block">Coming to</span>Google Play</span>
        </div>
        <div class="flex items-center gap-3 bg-gray-900 text-white rounded-xl px-4 py-2.5 opacity-50 cursor-not-allowed select-none text-sm">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span><span class="text-gray-400 text-xs block">Coming to</span>App Store</span>
        </div>
      </div>
    </div>

    <!-- Creator guide -->
    <div id="create">
      <h2 class="text-lg font-bold text-gray-900 mb-1">Create Your Own Game</h2>
      <p class="text-gray-500 text-sm mb-5">
        Games are pure data — JSON files that describe a board, entities, and rules.
        An AI assistant guides you from idea to a playable pack.
      </p>
      <ol class="space-y-4">
        {[
          { step: 1, title: 'Clone the repository',     code: 'git clone https://github.com/GridPonder/GridPonder' },
          { step: 2, title: 'Install Claude Code',      code: 'npm install -g @anthropic-ai/claude-code' },
          { step: 3, title: 'Open the repo and start Claude', code: 'cd GridPonder && claude' },
          { step: 4, title: 'Type the create-game command',   code: '/create-game' },
          { step: 5, title: 'Zip and share',            code: 'zip -r my-game.zip packs/my-game/' },
          { step: 6, title: 'Submit to the main repo',  code: undefined },
        ].map(({ step, title, code }) => (
          <li class="flex gap-3">
            <div class="flex-shrink-0 w-7 h-7 bg-brand-600 text-white rounded-full flex items-center justify-center text-xs font-bold">{step}</div>
            <div class="flex-1 min-w-0 pt-0.5">
              <p class="font-semibold text-gray-900 text-sm mb-1">{title}</p>
              {code && <code class="block bg-gray-900 text-green-400 font-mono text-xs px-3 py-2 rounded-lg overflow-x-auto">{code}</code>}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>

  <!-- =====================================================================
       DESKTOP VIEW  (hidden below lg)
       Phone frame (sticky) + sidebar
       ===================================================================== -->
  <div class="hidden lg:block">
    <div class="max-w-5xl mx-auto px-6 py-12">
      <div class="mb-10">
        <h1 class="text-4xl font-bold text-gray-900 mb-3">Play GridPonder</h1>
        <p class="text-gray-500 text-lg mb-5">All puzzle packs run directly in your browser. No installation needed.</p>
        <div class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 max-w-xl">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          <p class="text-sm text-amber-800">
            <span class="font-semibold">Best on a phone.</span>
            GridPonder is designed for touch. Open this page on your phone and add it to your home screen.
          </p>
        </div>
      </div>

      <div class="grid lg:grid-cols-[auto_1fr] gap-12 items-start">

        <!-- Phone frame — sticky -->
        <div class="flex flex-col items-center gap-4 sticky top-24">
          <div class="phone-frame">
            <iframe
              src="/game/"
              class="phone-screen"
              width="430"
              height="900"
              title="GridPonder game"
              loading="lazy"
              allow="fullscreen"
            ></iframe>
          </div>
          <p class="text-xs text-gray-400 text-center" style="max-width:430px">
            On a phone? <a href="/game/" class="text-brand-600 hover:underline">Open full screen</a> or add to your home screen.
          </p>
        </div>

        <!-- Right panel -->
        <div class="flex flex-col gap-10 lg:pt-4">

          <!-- App stores -->
          <div>
            <h2 class="text-xl font-bold text-gray-900 mb-1">Native App</h2>
            <p class="text-gray-500 text-sm mb-5">A native iOS and Android app is planned. Stay tuned.</p>
            <div class="flex flex-wrap gap-4">
              <div class="flex items-center gap-3 bg-gray-900 text-white rounded-xl px-5 py-3 opacity-50 cursor-not-allowed select-none">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76c.33.19.7.24 1.07.14l12.6-12.6-2.85-2.84L3.18 23.76zM20.69 10.37l-2.44-1.41-3.19 3.19 3.19 3.19 2.45-1.41c.7-.4.7-1.56-.01-1.56zM4.25.1C3.88 0 3.51.05 3.18.24L14 11.06l3.05-3.06L4.25.1zM2.82 1.05C2.31 1.5 2 2.22 2 3.1v17.8c0 .88.31 1.6.82 2.05l.12.1 9.97-9.97v-.22L2.94.95l-.12.1z"/></svg>
                <div><div class="text-xs text-gray-400">Coming to</div><div class="text-sm font-semibold">Google Play</div></div>
              </div>
              <div class="flex items-center gap-3 bg-gray-900 text-white rounded-xl px-5 py-3 opacity-50 cursor-not-allowed select-none">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                <div><div class="text-xs text-gray-400">Coming to</div><div class="text-sm font-semibold">App Store</div></div>
              </div>
            </div>
          </div>

          <!-- Creator guide -->
          <div id="create">
            <h2 class="text-xl font-bold text-gray-900 mb-1">Create Your Own Game</h2>
            <p class="text-gray-500 text-sm mb-6">
              Games are pure data — JSON files that describe a board, entities, and rules.
              An AI assistant guides you interactively from idea to a playable pack.
            </p>
            <ol class="space-y-5">
              {[
                { step: 1, title: 'Clone the repository',     code: 'git clone https://github.com/GridPonder/GridPonder', note: undefined },
                { step: 2, title: 'Install Claude Code',      code: 'npm install -g @anthropic-ai/claude-code', note: 'Or another AI coding assistant that supports slash commands.' },
                { step: 3, title: 'Open the repo and start Claude', code: 'cd GridPonder && claude', note: undefined },
                { step: 4, title: 'Type the create-game command',   code: '/create-game', note: 'Claude guides you through naming, mechanics, entities, levels, and theming — all interactively.' },
                { step: 5, title: 'Zip and share',            code: 'zip -r my-game.zip packs/my-game/', note: 'Send the zip to anyone with the GridPonder app. They can import it directly.' },
                { step: 6, title: 'Submit to the main repo',  code: undefined, note: 'If your game is well-crafted and broadly appealing, open a GitHub issue or ping @jens to get it included.' },
              ].map(({ step, title, code, note }) => (
                <li class="flex gap-4">
                  <div class="flex-shrink-0 w-8 h-8 bg-brand-600 text-white rounded-full flex items-center justify-center text-sm font-bold">{step}</div>
                  <div class="flex-1 min-w-0 pt-0.5">
                    <p class="font-semibold text-gray-900 mb-1">{title}</p>
                    {code && <code class="block bg-gray-900 text-green-400 font-mono text-sm px-4 py-2 rounded-lg mb-2 overflow-x-auto">{code}</code>}
                    {note && <p class="text-gray-500 text-sm">{note}</p>}
                  </div>
                </li>
              ))}
            </ol>
            <div class="mt-8 p-4 bg-brand-50 border border-brand-100 rounded-xl">
              <p class="text-sm text-brand-800">
                <span class="font-semibold">Game packs are data, not code.</span>
                The engine is fixed and sandboxed — imported packs cannot execute arbitrary code and are safe to share with anyone.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>
