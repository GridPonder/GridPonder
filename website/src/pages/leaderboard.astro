---
import { readFileSync, existsSync } from 'node:fs';
import { resolve } from 'node:path';
import Base from '../layouts/Base.astro';

const leaderboardPath = resolve(process.cwd(), '../tools/benchmark/leaderboard.json');
let models: any[] = [];
let generated: string | null = null;

if (existsSync(leaderboardPath)) {
  try {
    const leaderboard = JSON.parse(readFileSync(leaderboardPath, 'utf-8'));
    models = leaderboard.models ?? [];
    generated = leaderboard.generated
      ? new Date(leaderboard.generated).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
      : null;
  } catch {}
}

// All pack IDs across all entries (union, for table columns)
const allPacks = [...new Set(models.flatMap((m: any) => Object.keys(m.by_pack ?? {})))].sort() as string[];

const modelsJson = JSON.stringify(models);
const allPacksJson = JSON.stringify(allPacks);
---
<Base
  title="AI Leaderboard"
  description="Which AI models can solve GridPonder puzzles, and how efficiently? Rankings across packs and levels."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <!-- Header -->
    <div class="max-w-3xl mb-12">
      <div class="flex items-center gap-2 text-amber-600 font-mono text-sm mb-4">
        <span>🏆</span>
        <span>AI Benchmarks</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-black text-gray-900 mb-5 leading-tight">
        AI Leaderboard
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed">
        GridPonder levels are fully deterministic with verified gold paths, making them a clean benchmark
        for evaluating AI planning and spatial reasoning.
      </p>
    </div>

    <!-- How it works -->
    <div class="grid sm:grid-cols-3 gap-6 mb-16">
      <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
        <div class="text-3xl mb-3">🧩</div>
        <h2 class="font-bold text-gray-900 mb-2">What is measured</h2>
        <p class="text-sm text-gray-500 leading-relaxed">
          Each turn the model receives a <strong class="text-gray-700">text-based board</strong> rendered
          with Unicode symbols and a legend, the goal description, the last action taken and how the board
          changed, and the full list of valid actions. The model can also maintain a
          <strong class="text-gray-700">persistent memory</strong> string it updates freely across turns
          — its only way to retain knowledge between steps.
        </p>
      </div>
      <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
        <div class="text-3xl mb-3">📊</div>
        <h2 class="font-bold text-gray-900 mb-2">How scores work</h2>
        <ul class="mt-2 space-y-2 text-sm text-gray-500">
          <li><strong class="text-gray-700">Accuracy</strong> — fraction of levels solved within the total action budget.</li>
          <li><strong class="text-gray-700">Efficiency</strong> — gold path length ÷ actions used (1.0 = perfect). In flex-n mode the denominator is adjusted for batched steps.</li>
          <li><strong class="text-gray-700">Speed / Cost</strong> — median ms per LLM call (local models); average USD per level (API models).</li>
        </ul>
        <p class="mt-3 text-sm text-gray-500">
          Auto-reset triggers at 2× gold path length per attempt; total budget is 3× gold path across all attempts.
        </p>
      </div>
      <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
        <div class="text-3xl mb-3">🤖</div>
        <h2 class="font-bold text-gray-900 mb-2">Which models</h2>
        <p class="text-sm text-gray-500 leading-relaxed">
          Local models (Gemma 4, Qwen 3.5, GPT-OSS) run via <strong class="text-gray-700">Ollama</strong>.
          API models (Claude, GPT, Gemini, Grok) are included for accuracy comparison but excluded
          from the latency Pareto chart. The prompt is plain text — no vision or special modalities required.
        </p>
      </div>
    </div>

    <!-- Selectors: 5 valid combinations in 2 labelled groups -->
    <div class="mb-8">
      <div class="inline-flex flex-wrap items-center gap-1 bg-gray-100 rounded-xl p-1.5">
        <!-- Aggregate -->
        <button id="sel-aggregate" class="sel-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors text-gray-500 hover:text-gray-700">Aggregate</button>
        <div class="w-px h-5 bg-gray-300 mx-1"></div>
        <!-- Normal group -->
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide px-2">Normal</span>
        <button id="sel-normal-single" class="sel-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors bg-white text-gray-900 shadow-sm">Single-step</button>
        <button id="sel-normal-flex-n" class="sel-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors text-gray-500 hover:text-gray-700">Flex-n</button>
        <button id="sel-normal-full"   class="sel-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors text-gray-500 hover:text-gray-700">Full</button>
        <!-- Divider -->
        <div class="w-px h-5 bg-gray-300 mx-1"></div>
        <!-- Anon group -->
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide px-2">Anon</span>
        <button id="sel-anon-single"   class="sel-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors text-gray-500 hover:text-gray-700">Single-step</button>
        <button id="sel-anon-flex-n"   class="sel-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors text-gray-500 hover:text-gray-700">Flex-n</button>
      </div>
      <p id="combo-description" class="mt-3 text-sm text-gray-500 max-w-xl leading-relaxed"></p>
    </div>

    <!-- Overall leaderboard table -->
    <div class="rounded-2xl border border-gray-200 overflow-hidden mb-12">
      <div class="bg-gray-50 border-b border-gray-200 px-6 py-4 flex items-center justify-between">
        <h2 class="font-bold text-gray-900">Overall Rankings</h2>
        {generated
          ? <span class="text-xs text-gray-400 bg-white border border-gray-200 px-3 py-1 rounded-full">Updated {generated}</span>
          : <span class="text-xs text-gray-400 bg-white border border-gray-200 px-3 py-1 rounded-full">No data yet</span>
        }
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              {['#', 'Model', 'Type', 'Score', 'Accuracy', 'Efficiency', 'Cost', 'Score / $'].map(col => (
                <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">{col}</th>
              ))}
            </tr>
          </thead>
          <tbody id="overall-tbody" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </div>
    <p class="mt-3 text-xs text-gray-400 leading-relaxed">
      <strong class="text-gray-500">Score</strong> — 0.5 × accuracy + 0.5 × efficiency per level (failed levels contribute 0); used for ranking. &ensp;·&ensp;
      <strong class="text-gray-500">Accuracy</strong> — fraction of levels solved within the action budget. &ensp;·&ensp;
      <strong class="text-gray-500">Efficiency</strong> — gold path length ÷ actions used, on solved levels only (1.0 = optimal). &ensp;·&ensp;
      <strong class="text-gray-500">Cost</strong> — average USD per level (API models). &ensp;·&ensp;
      <strong class="text-gray-500">Score / $</strong> — aggregate score divided by cost per level; higher = better value (API models only).
      <span id="levels-footnote"></span>
    </p>

    <!-- Pareto chart -->
    <div class="rounded-2xl border border-gray-200 overflow-hidden mb-6 mt-10">
      <div class="bg-gray-50 border-b border-gray-200 px-6 py-4">
        <h2 class="font-bold text-gray-900">Cost vs. Score — API Models</h2>
        <p class="text-xs text-gray-500 mt-0.5">Blue = standard, purple = thinking/reasoning. Log scale on x-axis. Hover any dot for details.</p>
      </div>
      <div class="px-2 py-2" id="pareto-chart" style="height:380px"></div>
    </div>

    <!-- Per-pack breakdown -->
    <div id="pack-section" class="mb-12">
      <h2 class="font-bold text-gray-900 text-lg mb-4">Breakdown by Pack</h2>
      <div class="rounded-2xl border border-gray-200 overflow-hidden overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide sticky left-0 bg-gray-50 whitespace-nowrap">Model</th>
              {allPacks.map((pack: string) => (
                <th class="text-center px-3 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">{pack.replace(/_/g, ' ')}</th>
              ))}
            </tr>
          </thead>
          <tbody id="pack-tbody" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
      <p class="mt-2 text-xs text-gray-400">Values show accuracy (% levels solved). ✦ = thinking/reasoning enabled.</p>
    </div>

    <!-- How to run -->
    <div class="mt-4 p-8 bg-amber-50 rounded-2xl border border-amber-100">
      <h2 class="font-bold text-gray-900 text-lg mb-2">Running the benchmark</h2>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">
        The benchmark tool lives in <code class="bg-amber-100 px-1 py-0.5 rounded text-xs">tools/benchmark/</code>.
        Requires <a href="https://ollama.com" class="text-brand-600 hover:underline" target="_blank">Ollama</a> for local models,
        and API keys in <code class="bg-amber-100 px-1 py-0.5 rounded text-xs">.env</code> (copy from <code class="bg-amber-100 px-1 py-0.5 rounded text-xs">.env.example</code>) for cloud models.
      </p>
      <div class="space-y-2">
        {[
          ['Build the runner (once)',      'make benchmark-build'],
          ['Install Python deps',         'cd tools/benchmark && python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt'],
          ['Run local non-think (5 combos)', 'cd tools/benchmark && bash run_local_nothink.sh'],
          ['Run curated suite (all models)', 'make benchmark-suite'],
          ['Run all packs × all models',  'make benchmark'],
          ['Aggregate results',           'make benchmark-agg'],
        ].map(([label, code]) => (
          <div class="flex items-start gap-3">
            <span class="text-gray-500 text-sm min-w-[200px] pt-1.5">{label}</span>
            <code class="block bg-gray-900 text-green-400 font-mono text-xs px-3 py-2 rounded-lg flex-1">{code}</code>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script define:vars={{ modelsJson, allPacksJson }}>
    const ALL_MODELS = JSON.parse(modelsJson);
    const ALL_PACKS  = JSON.parse(allPacksJson);

    const COMBO_DESCRIPTIONS = {
      'aggregate|false': 'Average of score, accuracy, and efficiency across all five inference modes. Models without data for a mode are excluded from that mode\'s contribution.',
      'single|false': 'One action per LLM call. The model sees the current board state and picks exactly one move. The baseline interaction mode.',
      'flex-n|false': 'The model chooses 1–5 actions per call. Extra steps beyond the first are penalised (−0.5 per extra step), rewarding confident multi-step planning over move-by-move hedging.',
      'full|false':   'All actions in a single call — no intermediate feedback. The model must plan the complete solution upfront from the initial board state alone.',
      'single|true':  'Single-step with anonymised labels: entity kinds and action IDs are replaced with arbitrary codes (e.g. "entity_A", "action_3"). Tests whether performance depends on domain-familiar language rather than pure spatial reasoning.',
      'flex-n|true':  'Flex-n with anonymised labels: multi-step planning where all entity and action names carry no semantic meaning. The hardest test of label-independent reasoning.',
    };

    const COMBOS = [
      { id: 'sel-aggregate',     mode: 'aggregate', anon: false },
      { id: 'sel-normal-single', mode: 'single',    anon: false },
      { id: 'sel-normal-flex-n', mode: 'flex-n',    anon: false },
      { id: 'sel-normal-full',   mode: 'full',      anon: false },
      { id: 'sel-anon-single',   mode: 'single',    anon: true  },
      { id: 'sel-anon-flex-n',   mode: 'flex-n',    anon: true  },
    ];

    let currentMode = 'single';
    let currentAnon = false;

    function strip_provider(name) {
      return name.replace(/\s*\([^)]+\)$/, '');
    }

    function fmt_pct(v) {
      if (v == null) return '—';
      return (v * 100).toFixed(0) + '%';
    }
    function fmt_eff(v) {
      if (v == null) return '—';
      return v.toFixed(2);
    }
    // TODO: local model table — show p50_latency_ms here once local benchmark data exists.
    // fmt_lat is kept for that future use.
    function fmt_lat(v) {
      if (v == null) return '—';
      return v < 1000 ? `${v.toFixed(0)} ms` : `${(v / 1000).toFixed(1)} s`;
    }
    function fmt_cost(v) {
      if (v == null) return '—';
      if (v < 0.001) return '<$0.001';
      return `$${v.toFixed(3)}`;
    }
    function fmt_spd(score, cost) {
      if (score == null || cost == null || cost === 0) return '—';
      const v = score / cost;
      return v < 1 ? v.toFixed(2) : v.toFixed(1);
    }

    function computeAggregate() {
      const byId = {};
      for (const m of ALL_MODELS) {
        if (!byId[m.id]) byId[m.id] = { id: m.id, display_name: m.display_name, local: m.local, reasoning: m.reasoning, entries: [] };
        byId[m.id].entries.push(m);
      }
      const mean = (arr) => arr.length ? arr.reduce((a, b) => a + b, 0) / arr.length : null;
      return Object.values(byId).map(g => {
        const avg = field => mean(g.entries.map(e => e.overall?.[field]).filter(v => v != null));
        const packKeys = [...new Set(g.entries.flatMap(e => Object.keys(e.by_pack ?? {})))];
        const by_pack = {};
        for (const pack of packKeys) {
          const ps = g.entries.map(e => e.by_pack?.[pack]).filter(Boolean);
          const pavg = field => mean(ps.map(p => p[field]).filter(v => v != null));
          by_pack[pack] = { success_rate: pavg('success_rate'), avg_aggregate_score: pavg('avg_aggregate_score') };
        }
        return {
          id: g.id, display_name: g.display_name, local: g.local, reasoning: g.reasoning,
          inference_mode: 'aggregate', anon: false,
          overall: {
            avg_aggregate_score: avg('avg_aggregate_score'),
            success_rate:        avg('success_rate'),
            avg_efficiency:      avg('avg_efficiency'),
            p50_latency_ms:      avg('p50_latency_ms'),
            avg_cost_usd:        avg('avg_cost_usd'),
            levels_run:          g.entries.reduce((s, e) => s + (e.overall?.levels_run ?? 0), 0),
          },
          by_pack,
        };
      }).sort((a, b) => (b.overall.avg_aggregate_score ?? 0) - (a.overall.avg_aggregate_score ?? 0));
    }

    function getModels() {
      if (currentMode === 'aggregate') return computeAggregate();
      return ALL_MODELS.filter(m =>
        m.inference_mode === currentMode &&
        (m.anon ?? false) === currentAnon
      );
    }

    function renderOverall(models) {
      const tbody = document.getElementById('overall-tbody');
      if (!models.length) {
        tbody.innerHTML = `
          <tr>
            <td colspan="8" class="px-6 py-20 text-center">
              <div class="flex flex-col items-center gap-4 text-gray-400">
                <span class="text-5xl">🤖</span>
                <div>
                  <p class="font-semibold text-gray-500 mb-1">No results yet for this configuration</p>
                  <p class="text-sm">Run <code class="bg-gray-100 px-1 rounded">bench.py --mode ${currentMode}${currentAnon ? ' --anon' : ''}</code> to generate data.</p>
                </div>
              </div>
            </td>
          </tr>`;
        return;
      }
      tbody.innerHTML = models.map((m, i) => `
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3 text-gray-400 font-mono">${i + 1}</td>
          <td class="px-4 py-3">
            <span class="font-semibold text-gray-900">${strip_provider(m.display_name)}</span>
            ${m.reasoning ? '<span class="ml-2 text-xs bg-purple-100 text-purple-700 px-1.5 py-0.5 rounded font-medium">thinking</span>' : ''}
          </td>
          <td class="px-4 py-3">
            ${m.local
              ? '<span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded font-medium">local</span>'
              : '<span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded font-medium">API</span>'
            }
          </td>
          <td class="px-4 py-3 font-mono font-semibold text-gray-900">${fmt_eff(m.overall?.avg_aggregate_score)}</td>
          <td class="px-4 py-3 font-mono text-gray-700">${fmt_pct(m.overall?.success_rate)}</td>
          <td class="px-4 py-3 font-mono text-gray-700">${fmt_eff(m.overall?.avg_efficiency)}</td>
          <td class="px-4 py-3 font-mono text-gray-500">${m.local ? '—' : fmt_cost(m.overall?.avg_cost_usd)}</td>
          <td class="px-4 py-3 font-mono text-gray-500">${m.local ? '—' : fmt_spd(m.overall?.avg_aggregate_score, m.overall?.avg_cost_usd)}</td>
        </tr>`
      ).join('');
    }

    function renderPacks(models) {
      const section = document.getElementById('pack-section');
      const tbody   = document.getElementById('pack-tbody');
      if (!models.length || !ALL_PACKS.length) {
        section.style.display = 'none';
        return;
      }
      section.style.display = '';
      tbody.innerHTML = models.map(m => `
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3 sticky left-0 bg-white font-semibold text-gray-800 whitespace-nowrap">
            ${strip_provider(m.display_name)}
            ${m.reasoning ? '<span class="ml-1 text-xs text-purple-500">✦</span>' : ''}
          </td>
          ${ALL_PACKS.map(pack => {
            const ps = m.by_pack?.[pack];
            if (!ps) return '<td class="px-3 py-3 text-center"><span class="text-gray-300">—</span></td>';
            const sr = ps.success_rate ?? 0;
            const cls = sr >= 0.8 ? 'text-green-700 font-semibold' : sr >= 0.5 ? 'text-amber-700' : 'text-red-600';
            return `<td class="px-3 py-3 text-center"><span class="font-mono text-xs ${cls}">${fmt_pct(ps.success_rate)}</span></td>`;
          }).join('')}
        </tr>`
      ).join('');
    }

    const BASE_BTN   = 'sel-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-colors';
    const ACTIVE_CLS = 'bg-white text-gray-900 shadow-sm';
    const INACTIVE   = 'text-gray-500 hover:text-gray-700';

    function updateSelectors() {
      COMBOS.forEach(({ id, mode, anon }) => {
        const active = mode === currentMode && anon === currentAnon;
        document.getElementById(id).className = `${BASE_BTN} ${active ? ACTIVE_CLS : INACTIVE}`;
      });
      const key = `${currentMode}|${currentAnon}`;
      document.getElementById('combo-description').textContent = COMBO_DESCRIPTIONS[key] ?? '';
    }

    // Lazy-load ECharts from CDN the first time the chart is needed.
    let _ec = null;
    function getECharts() {
      if (_ec) return Promise.resolve(_ec);
      if (window.echarts) return Promise.resolve((_ec = window.echarts));
      return new Promise(resolve => {
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js';
        s.onload = () => resolve((_ec = window.echarts));
        document.head.appendChild(s);
      });
    }

    let _paretoChart = null;

    async function renderPareto(models) {
      const el = document.getElementById('pareto-chart');
      if (!el) return;

      const pts = models.filter(m =>
        !m.local &&
        (m.overall?.avg_cost_usd ?? 0) > 0 &&
        m.overall?.avg_aggregate_score != null
      );

      if (!pts.length) {
        if (_paretoChart) { _paretoChart.clear(); }
        el.innerHTML = '<p class="py-12 text-center text-sm text-gray-400">No API model data for this mode.</p>';
        return;
      }

      const echarts = await getECharts();
      if (!_paretoChart) {
        el.innerHTML = '';
        _paretoChart = echarts.init(el);
        new ResizeObserver(() => _paretoChart?.resize()).observe(el);
      }

      const fmtCost = v => v < 0.1 ? `$${v.toFixed(2)}` : `$${v.toFixed(1)}`;

      _paretoChart.setOption({
        grid: { top: 20, right: 160, bottom: 52, left: 52 },
        xAxis: {
          type: 'log', logBase: 10,
          name: 'avg. cost per level (USD, log scale)',
          nameLocation: 'center', nameGap: 36,
          axisLine: { lineStyle: { color: '#d1d5db' } },
          axisTick: { lineStyle: { color: '#d1d5db' } },
          splitLine: { lineStyle: { color: '#f3f4f6' } },
          axisLabel: { color: '#9ca3af', fontSize: 11, formatter: fmtCost },
        },
        yAxis: {
          type: 'value', name: 'score',
          nameLocation: 'center', nameGap: 36,
          min: 0, max: 1,
          axisLine: { show: true, lineStyle: { color: '#d1d5db' } },
          axisTick: { lineStyle: { color: '#d1d5db' } },
          splitLine: { lineStyle: { color: '#f3f4f6' } },
          axisLabel: { color: '#9ca3af', fontSize: 11 },
        },
        tooltip: {
          trigger: 'item',
          formatter: p => `${p.name}<br/>Score: ${p.value[1].toFixed(3)}<br/>Cost: $${p.value[0].toFixed(3)}/lvl`,
        },
        // Single series so moveOverlap deduplicates across all labels at once.
        series: [{
          type: 'scatter',
          data: pts.map(m => ({
            name: strip_provider(m.display_name) + (m.reasoning ? ' ✦' : ''),
            value: [m.overall.avg_cost_usd, m.overall.avg_aggregate_score],
            itemStyle: { color: m.reasoning ? '#7c3aed' : '#3b82f6', borderColor: 'white', borderWidth: 1.5 },
          })),
          symbolSize: 9,
          label: { show: true, formatter: p => p.name, position: 'right', color: '#374151', fontSize: 11 },
          labelLayout: { hideOverlap: true },
        }],
      }, true);
    }

    async function render() {
      const models = getModels();
      renderOverall(models);
      await renderPareto(models);
      renderPacks(models);
      updateSelectors();
      const n = currentMode !== 'aggregate' ? models[0]?.overall?.levels_run : null;
      const fn = document.getElementById('levels-footnote');
      if (fn) fn.textContent = n != null ? ` · ${n} levels tested per model.` : '';
    }

    // Wire up all 5 buttons
    COMBOS.forEach(({ id, mode, anon }) => {
      document.getElementById(id).addEventListener('click', () => {
        currentMode = mode;
        currentAnon = anon;
        render();
      });
    });

    // Initial render
    render();
  </script>
</Base>
